{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hando",
  "mainBinaryName": "hando",
  "version": "0.2.0",
  "identifier": "com.hando.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hando",
        "width": 720,
        "height": 520,
        "minWidth": 560,
        "minHeight": 400,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
"windows": {
      "nsis": {
        "installMode": "both",
        "headerImage": "assets/installer-header.bmp"
      }
    }
  }
}
